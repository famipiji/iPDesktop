<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pdf="clr-namespace:Syncfusion.Maui.PdfViewer;assembly=Syncfusion.Maui.PdfViewer"
             x:Class="iPDesktop.DocumentPreviewPage"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*" BackgroundColor="{StaticResource Gray100}">

        <!-- Header -->
        <Grid Grid.Row="0"
              BackgroundColor="{StaticResource Primary}"
              Padding="12,10"
              ColumnDefinitions="Auto,*,Auto">

            <Button Grid.Column="0"
                    Text="← Back"
                    Clicked="OnBackClicked"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    FontSize="14"
                    Padding="8,0" />

            <VerticalStackLayout Grid.Column="1"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="2">
                <Label x:Name="FileNameLabel"
                       Text=""
                       FontSize="15"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="TailTruncation"
                       MaxLines="1" />
                <Label x:Name="FileMetaLabel"
                       Text=""
                       FontSize="12"
                       TextColor="{StaticResource Secondary}"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <HorizontalStackLayout Grid.Column="2" Spacing="8" VerticalOptions="Center">
                <Button x:Name="OcrBtn"
                        Text="FlyOCR"
                        Clicked="OnOcrModeToggled"
                        BackgroundColor="White"
                        TextColor="{StaticResource Primary}"
                        FontSize="13"
                        CornerRadius="6"
                        HeightRequest="34"
                        Padding="12,0"
                        IsVisible="False" />
            </HorizontalStackLayout>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="1">

            <!-- Loading -->
            <VerticalStackLayout x:Name="LoadingView"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="16">
                <ActivityIndicator IsRunning="True"
                                   Color="{StaticResource Primary}"
                                   WidthRequest="48"
                                   HeightRequest="48" />
                <Label Text="Preparing PDF preview…"
                       FontSize="14"
                       TextColor="{StaticResource Gray400}"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Syncfusion PDF Viewer -->
            <pdf:SfPdfViewer x:Name="PdfViewer"
                             IsVisible="False" />

            <!-- Unsupported file type -->
            <VerticalStackLayout x:Name="UnsupportedView"
                                 IsVisible="False"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="16"
                                 Padding="40">
                <Label Text="📄"
                       FontSize="64"
                       HorizontalTextAlignment="Center" />
                <Label x:Name="UnsupportedLabel"
                       FontSize="15"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Gray900}"
                       HorizontalTextAlignment="Center" />
                <Label Text="No PDF preview available for this file type."
                       FontSize="13"
                       TextColor="{StaticResource Gray400}"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Error -->
            <VerticalStackLayout x:Name="ErrorView"
                                 IsVisible="False"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="12">
                <Label Text="⚠️"
                       FontSize="48"
                       HorizontalTextAlignment="Center" />
                <Label x:Name="ErrorLabel"
                       FontSize="14"
                       TextColor="{StaticResource Gray500}"
                       HorizontalTextAlignment="Center"
                       Padding="32,0" />
            </VerticalStackLayout>

            <!-- Crop overlay — rendered on top of PdfViewer when OCR mode is active -->
            <GraphicsView x:Name="CropCanvas"
                          IsVisible="False"
                          InputTransparent="False"
                          BackgroundColor="Transparent">
                <GraphicsView.GestureRecognizers>
                    <PointerGestureRecognizer
                        PointerPressed="OnCropPointerPressed"
                        PointerMoved="OnCropPointerMoved"
                        PointerReleased="OnCropPointerReleased" />
                    <PanGestureRecognizer
                        PanUpdated="OnCropPanUpdated" />
                </GraphicsView.GestureRecognizers>
            </GraphicsView>

            <!-- OCR instruction banner — sits at top of content, above crop canvas -->
            <Border x:Name="OcrBanner"
                    IsVisible="False"
                    BackgroundColor="#CC000000"
                    StrokeThickness="0"
                    Padding="16,10"
                    VerticalOptions="Start">
                <Label Text="Draw a rectangle over the text you want to extract  ·  tap Cancel OCR to exit"
                       TextColor="White"
                       FontSize="12"
                       HorizontalTextAlignment="Center" />
            </Border>

        </Grid>
    </Grid>

</ContentPage>
