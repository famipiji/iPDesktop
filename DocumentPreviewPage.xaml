<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="iPDesktop.DocumentPreviewPage"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*" BackgroundColor="{StaticResource Gray100}">

        <!-- Header -->
        <Grid Grid.Row="0"
              BackgroundColor="{StaticResource Primary}"
              Padding="12,10"
              ColumnDefinitions="Auto,*,Auto">

            <Button Grid.Column="0"
                    Text="← Back"
                    Clicked="OnBackClicked"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    FontSize="14"
                    Padding="8,0" />

            <VerticalStackLayout Grid.Column="1"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="2">
                <Label x:Name="FileNameLabel"
                       Text=""
                       FontSize="15"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="TailTruncation"
                       MaxLines="1" />
                <Label x:Name="FileMetaLabel"
                       Text=""
                       FontSize="12"
                       TextColor="{StaticResource Secondary}"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <Button Grid.Column="2"
                    x:Name="OpenExternalBtn"
                    Text="Open"
                    Clicked="OnOpenExternalClicked"
                    BackgroundColor="White"
                    TextColor="{StaticResource Primary}"
                    FontSize="13"
                    CornerRadius="6"
                    HeightRequest="34"
                    Padding="12,0"
                    IsVisible="False" />
        </Grid>

        <!-- Content area -->
        <Grid Grid.Row="1">

            <!-- Loading spinner — visible until preview loads -->
            <VerticalStackLayout x:Name="LoadingView"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="16">
                <ActivityIndicator IsRunning="True"
                                   Color="{StaticResource Primary}"
                                   WidthRequest="48"
                                   HeightRequest="48" />
                <Label Text="Loading preview..."
                       FontSize="14"
                       TextColor="{StaticResource Gray400}"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Image preview -->
            <ScrollView x:Name="ImageView" IsVisible="False">
                <Image x:Name="PreviewImage"
                       Aspect="AspectFit"
                       Margin="16" />
            </ScrollView>

            <!-- PDF / HTML preview via WebView -->
            <WebView x:Name="PdfView"
                     IsVisible="False"
                     Margin="0" />

            <!-- Plain text preview -->
            <ScrollView x:Name="TextView" IsVisible="False">
                <Label x:Name="TextContent"
                       FontFamily="OpenSansRegular"
                       FontSize="13"
                       TextColor="{StaticResource Gray900}"
                       Padding="20"
                       LineBreakMode="WordWrap" />
            </ScrollView>

            <!-- Generic / unsupported -->
            <VerticalStackLayout x:Name="GenericView"
                                 IsVisible="False"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="16"
                                 Padding="32">

                <Label x:Name="GenericIcon"
                       Text="📄"
                       FontSize="64"
                       HorizontalTextAlignment="Center" />

                <Label x:Name="GenericFileName"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Gray900}"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="WordWrap" />

                <Label x:Name="GenericMeta"
                       FontSize="13"
                       TextColor="{StaticResource Gray500}"
                       HorizontalTextAlignment="Center" />

                <Label Text="No preview available for this file type."
                       FontSize="13"
                       TextColor="{StaticResource Gray400}"
                       HorizontalTextAlignment="Center"
                       Margin="0,8,0,0" />

                <Button Text="Open with default app"
                        Clicked="OnOpenExternalClicked"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        CornerRadius="8"
                        HeightRequest="44"
                        Margin="0,8,0,0" />
            </VerticalStackLayout>

            <!-- Error view -->
            <VerticalStackLayout x:Name="ErrorView"
                                 IsVisible="False"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="12">
                <Label Text="⚠️"
                       FontSize="48"
                       HorizontalTextAlignment="Center" />
                <Label x:Name="ErrorLabel"
                       FontSize="14"
                       TextColor="{StaticResource Gray500}"
                       HorizontalTextAlignment="Center"
                       Padding="32,0" />
            </VerticalStackLayout>

        </Grid>
    </Grid>

</ContentPage>
